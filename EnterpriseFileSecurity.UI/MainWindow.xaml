<Window x:Class="EnterpriseFileSecurity.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SecFS 企业文件安全访问控制系统"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="6" Padding="15" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔒 SecFS — 企业文件安全访问控制系统" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 主体区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧导航 -->
            <Border Grid.Column="0" Background="White" CornerRadius="6" Padding="10" Margin="0,0,10,0">
                <StackPanel>
                    <Button x:Name="BtnLogin" Content="🔑 用户登录" Height="40" Margin="0,5" Click="BtnLogin_Click"/>
                    <Button x:Name="BtnFiles" Content="📁 文件管理" Height="40" Margin="0,5" Click="BtnFiles_Click"/>
                    <Button x:Name="BtnKeys" Content="🔐 密钥管理" Height="40" Margin="0,5" Click="BtnKeys_Click"/>
                    <Button x:Name="BtnUSB" Content="🔌 USB管控" Height="40" Margin="0,5" Click="BtnUSB_Click"/>
                    <Button x:Name="BtnAudit" Content="📋 审计日志" Height="40" Margin="0,5" Click="BtnAudit_Click"/>
                    <Button x:Name="BtnAdmin" Content="👤 用户管理" Height="40" Margin="0,5" Click="BtnAdmin_Click" Visibility="Collapsed"/>
                    <Separator Margin="0,15"/>
                    <TextBlock x:Name="TxtStatus" Text="状态：未登录" Foreground="Gray" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- 右侧内容区 -->
            <Border Grid.Column="1" Background="White" CornerRadius="6" Padding="15">
                <StackPanel x:Name="ContentPanel">
                    <TextBlock Text="欢迎使用 SecFS 企业文件安全访问控制系统" FontSize="18" FontWeight="Bold" Margin="0,20"/>
                    <TextBlock Text="请先登录以访问加密文件。" FontSize="14" Foreground="Gray" Margin="0,10"/>
                    <TextBlock Text="· 支持 AES-256-GCM + RSA-2048 混合加密体系" FontSize="13" Margin="0,5"/>
                    <TextBlock Text="· 基于角色的访问控制(RBAC)，四级权限矩阵" FontSize="13" Margin="0,5"/>
                    <TextBlock Text="· USB外设白名单管控，防未授权数据泄露" FontSize="13" Margin="0,5"/>
                    <TextBlock Text="· 全链路审计日志，所有操作可追溯" FontSize="13" Margin="0,5"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="#E0E0E0" CornerRadius="4" Padding="10,5" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TxtFooter" Text="就绪" Foreground="#555" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
